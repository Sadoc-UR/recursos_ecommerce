{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PermitirSoloDesdeAmplify",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::e-commerce-e2/*",
      "Condition": {
        "StringLike": {
          "aws:Referer": [
            "https://main.d24el0ibgkta2q.amplifyapp.com/*",
            "http://localhost:3000/*",
            "http://localhost:5173/*"
          ]
        }
      }
    }
  ]
}